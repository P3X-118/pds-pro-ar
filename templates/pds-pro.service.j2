[Unit]
Description=PDS-Pro ({{ pds_pro_identifier }})
{% for service in (pds_pro_systemd_required_services_list + (pds_pro_systemd_required_services_list_auto | from_yaml if pds_pro_systemd_required_services_list_auto is string else pds_pro_systemd_required_services_list_auto)) %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in (pds_pro_systemd_wanted_services_list + (pds_pro_systemd_wanted_services_list_auto | from_yaml if pds_pro_systemd_wanted_services_list_auto is string else pds_pro_systemd_wanted_services_list_auto)) %}
Wants={{ service }}
{% endfor %}

[Service]
Type=simple
Environment="HOME={{ sysd_docker_unit_home_path }}"
ExecStartPre=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} stop -t {{ pds_pro_container_stop_grace_time_seconds | default(30) }} {{ pds_pro_identifier }} 2>/dev/null || true'
ExecStartPre=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} rm {{ pds_pro_identifier }} 2>/dev/null || true'

ExecStartPre={{ sysd_docker_host_command }} create \
      --rm \
      --name={{ pds_pro_identifier }} \
      --log-driver=none \
      --user={{ pds_pro_uid }}:{{ pds_pro_gid }} \
      --cap-drop=ALL \
      --read-only \
      --tmpfs=/tmp:rw,noexec,nosuid,size=50m \
      --network={{ pds_pro_container_network }} \
      {% set additional_networks = (pds_pro_container_additional_networks_auto | from_yaml if pds_pro_container_additional_networks_auto is string else pds_pro_container_additional_networks_auto) %}
      {% for network in (pds_pro_container_additional_networks + additional_networks) %}
      --network-alias={{ pds_pro_identifier }} \
      {% endfor %}
      {% if pds_pro_container_labels_traefik_enabled | bool %}
      --label "traefik.enable=true" \
      --label "traefik.docker.network={{ pds_pro_container_labels_traefik_docker_network }}" \
      --label "traefik.http.routers.{{ pds_pro_identifier }}.rule={{ pds_pro_container_labels_traefik_rule }}" \
      --label "traefik.http.routers.{{ pds_pro_identifier }}.entrypoints={{ pds_pro_container_labels_traefik_entrypoints }}" \
      --label "traefik.http.routers.{{ pds_pro_identifier }}.tls.certResolver={{ pds_pro_container_labels_traefik_tls_certResolver }}" \
      --label "traefik.http.services.{{ pds_pro_identifier }}.loadbalancer.server.port=8080" \
      {% for label in pds_pro_container_labels_traefik_additional_labels %}
      --label "{{ label }}" \
      {% endfor %}
      {% endif %}
      --mount type=bind,src={{ pds_pro_etc_path }}/config.yaml,dst=/etc/pds-pro/config.yaml,ro \
      --mount type=bind,src={{ pds_pro_secrets_path }},dst=/etc/pds-pro/secrets,ro \
      --mount type=bind,src={{ pds_pro_state_path }},dst=/etc/pds-pro/state \
      {{ pds_pro_container_image }} \
      pds-pro --config /etc/pds-pro/config.yaml --templates /app/web/templates

{% set additional_networks = (pds_pro_container_additional_networks_auto | from_yaml if pds_pro_container_additional_networks_auto is string else pds_pro_container_additional_networks_auto) %}
{% for network in (pds_pro_container_additional_networks + additional_networks) %}
ExecStartPre={{ sysd_docker_host_command }} network connect {{ network }} {{ pds_pro_identifier }}
{% endfor %}

ExecStart={{ sysd_docker_host_command }} start --attach {{ pds_pro_identifier }}

ExecStop=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} stop -t {{ pds_pro_container_stop_grace_time_seconds | default(30) }} {{ pds_pro_identifier }} 2>/dev/null || true'
ExecStop=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} rm {{ pds_pro_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ pds_pro_identifier }}

[Install]
WantedBy=multi-user.target
